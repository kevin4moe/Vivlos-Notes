{
  "manifest_version": 2,
  "name": "Quick Prompt Notes",
  "version": "0.1.0",
  "description": "Save prompt snippets, URLs, and quick notes with fast local search.",
  "permissions": ["storage", "activeTab", "tabs"],
  "browser_action": {
    "default_title": "Quick Prompt Notes",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png",
      "96": "icons/icon96.png"
    }
  },
  "options_ui": {
    "page": "manager.html",
    "open_in_tab": true
  },
  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "quick-prompt-notes@example.local",
      "strict_min_version": "109.0"
    }
  }
}
